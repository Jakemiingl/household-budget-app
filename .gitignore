# Secrets — never commit
.env

# Local data — the SQLite DB, logs, and any runtime artifacts.
# Ignore everything under data/ but keep the (empty) directory itself.
data/*
!data/.gitkeep

# Defense in depth: never commit a database or env file from ANY location.
*.db
*.db-journal
*.db-wal
*.db-shm
.env.*
!.env.example

# Python
.venv/
__pycache__/
*.pyc

# OS
Thumbs.db
.DS_Store
