# Copy this file to ".env" and fill in your values. .env is git-ignored.

# --- Plaid (bank data sync) ---
# Get these free at https://dashboard.plaid.com  (Keys page)
# Start with "sandbox" to develop against fake banks at no cost.
PLAID_ENV=sandbox
PLAID_CLIENT_ID=
PLAID_SECRET=

# --- AI chat (Claude Code CLI, uses your subscription) ---
# Path to the claude executable. Default works for a standard npm install on Windows.
CLAUDE_CLI_PATH=claude
# Model alias for budget chat. 'haiku' is fast & light on your plan limits.
# Other options: 'sonnet', 'opus'.
CLAUDE_MODEL=haiku

# --- Telegram bot (optional: ask the assistant from your phone) ---
# 1. In Telegram, message @BotFather, send /newbot, follow prompts, copy the token.
# 2. Paste it below and restart. Message your new bot once; it replies with your
#    chat ID. Put that ID (and your spouse's) in TELEGRAM_ALLOWED_CHAT_IDS, restart.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# --- App ---
APP_HOST=127.0.0.1
APP_PORT=8765
